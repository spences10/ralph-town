# Daytona API key for local ralph-town orchestration.
# Get one from https://app.daytona.io/dashboard/keys
DAYTONA_API_KEY=

# Daytona target region (us, eu, asia)
DAYTONA_TARGET=us

# Optional local GitHub token for commands run on your machine.
# Do not pass this into disposable sandboxes unless you intend to.
GH_TOKEN=

# Optional local Anthropic key for commands run on your machine.
# Do not pass this into disposable sandboxes unless you intend to.
ANTHROPIC_API_KEY=

# Sandbox-scoped GitHub token. When supplied via --env-file or --env,
# ralph-town forwards this into the sandbox as GH_TOKEN.
# GITHUB_PAT is still accepted as a deprecated compatibility alias.
SANDBOX_GH_TOKEN=

# Sandbox-scoped Anthropic key. When supplied via --env-file or --env,
# ralph-town forwards this into the sandbox as ANTHROPIC_API_KEY.
SANDBOX_ANTHROPIC_API_KEY=
